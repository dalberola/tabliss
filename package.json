{
  "name": "tabliss",
  "version": "2.8.2",
  "license": "GPL-3.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "browserslist": [
    "last 2 versions",
    "Firefox ESR",
    "not dead",
    "not IE 11"
  ],
  "scripts": {
    "build": "npm run build:web",
    "build:chromium": "NODE_ENV=production BUILD_TARGET=chromium webpack",
    "build:firefox": "NODE_ENV=production BUILD_TARGET=firefox webpack",
    "build:web": "NODE_ENV=production BUILD_TARGET=web webpack",
    "dev": "npm run dev:web",
    "dev:chromium": "BUILD_TARGET=chromium webpack --watch",
    "dev:firefox": "BUILD_TARGET=firefox webpack --watch",
    "dev:web": "BUILD_TARGET=web webpack serve",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "tsc -p tsconfig.test.json && jest",
    "translations": "node ./scripts/translations.js"
  },
  "dependencies": {
    "@sentry/browser": "^10.60.0",
    "core-js": "^3.49.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "feather-icons": "^4.29.2",
    "github-calendar": "^2.3.4",
    "in-browser-language": "^1.0.3",
    "nanoid": "^3.3.15",
    "normalize.css": "^8.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-error-boundary": "^6.1.2",
    "react-intl": "^10.1.9",
    "tlds": "^1.261.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "3.8.4",
    "react-intl-translations-manager": "^5.0.3",
    "sass": "^1.100.0",
    "sass-loader": "^17.0.0",
    "ts-loader": "^9.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "typescript-react-intl": "^0.4.1",
    "webpack": "^5.107.1",
    "webpack-cli": "^7.0.3",
    "webpack-dev-server": "^5.2.4",
    "workbox-webpack-plugin": "^7.4.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
